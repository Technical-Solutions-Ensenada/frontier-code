---
import Container from "../../components/ui/Container.astro";
import imagotipoColor from "../../assets/IMAGOTIPO/SVG/IMAGOTIPO - DOS TONOS CLARO DEGRADADO.svg";

const navLinks = [
  { href: "#hero", label: "Inicio" },
  { href: "#about", label: "Nosotros" },
  { href: "#process", label: "Proceso" },
  { href: "#services", label: "Servicios" },
  { href: "#portfolio", label: "Portafolio" },
  { href: "#team", label: "Equipo" },
  { href: "#contact", label: "Contacto" },
];
---

<header
  class="sticky top-0 z-50 bg-brand-dark/80 backdrop-blur-xl border-b border-brand-cyan/20"
>
  <Container>
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="shrink-0">
        <img
          src={imagotipoColor.src}
          alt="Frontier Code"
          class="w-20 sm:w-28 lg:w-40 transition-transform duration-300 hover:scale-105"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="relative px-4 py-2 text-dark-300 hover:text-brand-cyan transition-all duration-300 hover:scale-105 group rounded-lg"
            >
              <span class="relative z-10">{link.label}</span>
              <span class="absolute inset-0 bg-brand-cyan/10 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            </a>
          ))
        }
      </div>

      <!-- CTA + Mobile Toggle -->
      <div class="hidden md:flex items-center gap-4 ml-4">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-2.5 bg-linear-to-r from-brand-cyan to-brand-blue text-white font-semibold rounded-lg hover:opacity-90 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-brand-cyan/50"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
            ></path>
          </svg>
          <span>Contáctanos</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="md:hidden p-2 text-brand-cyan hover:bg-brand-cyan/10 rounded-lg transition-colors"
        aria-label="Abrir menú"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </nav>
  </Container>
</header>
