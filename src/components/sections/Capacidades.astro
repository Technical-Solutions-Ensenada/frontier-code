---
// src/sections/Capabilities.astro
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
---

<Section id="capabilities" background="dark" class="pt-0!">
    <Container>
        <div class="relative py-20 sm:py-28 lg:py-36">
            <!-- Header -->
            <div class="relative text-center mb-20">
                <h2
                    class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-frontier-light mb-6"
                >
                    <span
                        class="bg-brand-gradient bg-clip-text text-transparent"
                    >
                        Capacidades Técnicas Avanzadas
                    </span>
                </h2>
                <p
                    class="text-lg sm:text-xl text-frontier-light/70 leading-relaxed max-w-3xl mx-auto"
                >
                    Tecnología de punta que potencia cada solución que
                    desarrollamos
                </p>
            </div>

            <!-- Bento Grid -->
            <div
                id="bento-grid"
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 auto-rows-[240px]"
            >
                <!-- Tarjeta 1: Cloud (grande, ocupa 2 columnas y 2 filas) -->
                <div
                    class="bento-card group relative col-span-1 lg:col-span-2 row-span-2 bg-frontier-dark/40 border border-frontier-cyan/20 rounded-2xl p-8 hover:border-frontier-cyan/50 transition-all duration-500 hover:shadow-xl hover:shadow-frontier-cyan/10 overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-linear-to-br from-frontier-cyan/0 to-frontier-cyan/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative flex flex-col h-full">
                        <div class="flex items-center gap-4 mb-4">
                            <div
                                class="w-14 h-14 bg-frontier-cyan/20 border-2 border-frontier-cyan/40 rounded-xl flex items-center justify-center shadow-lg shadow-frontier-cyan/20"
                            >
                                <span
                                    class="text-2xl font-bold bg-brand-gradient text-transparent bg-clip-text"
                                    >01</span
                                >
                            </div>
                            <h4
                                class="text-xl font-bold text-frontier-light group-hover:text-frontier-cyan transition-colors"
                            >
                                Infraestructura Cloud
                            </h4>
                        </div>
                        <p class="text-frontier-light/70 flex-1">
                            Dominio en arquitecturas AWS y microservicios
                            enfocado en eficiencia de costos, rentabilidad
                            operativa y capacidad de manejar alta carga con
                            escalabilidad automática.
                        </p>
                        <div
                            class="h-1 w-0 group-hover:w-full bg-brand-gradient rounded-full transition-all duration-700 mt-4"
                        >
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 2: Automatización (estándar) -->
                <div
                    class="bento-card group relative bg-frontier-dark/40 border border-frontier-blue/20 rounded-2xl p-8 hover:border-frontier-blue/50 transition-all duration-500 hover:shadow-xl hover:shadow-frontier-blue/10 overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-linear-to-br from-frontier-blue/0 to-frontier-blue/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative flex flex-col h-full">
                        <div class="flex items-center gap-4 mb-4">
                            <div
                                class="w-14 h-14 bg-frontier-blue/20 border-2 border-frontier-blue/40 rounded-xl flex items-center justify-center shadow-lg shadow-frontier-blue/20"
                            >
                                <span
                                    class="text-2xl font-bold bg-brand-gradient text-transparent bg-clip-text"
                                    >02</span
                                >
                            </div>
                            <h4
                                class="text-xl font-bold text-frontier-light group-hover:text-frontier-blue transition-colors"
                            >
                                Automatización
                            </h4>
                        </div>
                        <p class="text-frontier-light/70 flex-1">
                            Eliminación de procesos manuales mediante CI/CD,
                            integración con sistemas contables y optimización de
                            cadenas de suministro.
                        </p>
                        <div
                            class="h-1 w-0 group-hover:w-full bg-brand-gradient rounded-full transition-all duration-700 mt-4"
                        >
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 3: Seguridad (estándar) -->
                <div
                    class="bento-card group relative bg-frontier-dark/40 border border-frontier-cyan/20 rounded-2xl p-8 hover:border-frontier-cyan/50 transition-all duration-500 hover:shadow-xl hover:shadow-frontier-cyan/10 overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-linear-to-br from-frontier-cyan/0 to-frontier-cyan/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative flex flex-col h-full">
                        <div class="flex items-center gap-4 mb-4">
                            <div
                                class="w-14 h-14 bg-frontier-cyan/20 border-2 border-frontier-cyan/40 rounded-xl flex items-center justify-center shadow-lg shadow-frontier-cyan/20"
                            >
                                <span
                                    class="text-2xl font-bold bg-brand-gradient text-transparent bg-clip-text"
                                    >03</span
                                >
                            </div>
                            <h4
                                class="text-xl font-bold text-frontier-light group-hover:text-frontier-cyan transition-colors"
                            >
                                Seguridad y Trazabilidad
                            </h4>
                        </div>
                        <p class="text-frontier-light/70 flex-1">
                            Integridad de la información con control de activos,
                            monitoreo en tiempo real de seguridad y cumplimiento
                            normativo.
                        </p>
                        <div
                            class="h-1 w-0 group-hover:w-full bg-brand-gradient rounded-full transition-all duration-700 mt-4"
                        >
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 4: Integración (horizontal, ocupa 2 columnas) -->
                <div
                    class="bento-card group relative col-span-1 lg:col-span-2 bg-frontier-dark/40 border border-frontier-blue/20 rounded-2xl p-8 hover:border-frontier-blue/50 transition-all duration-500 hover:shadow-xl hover:shadow-frontier-blue/10 overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-linear-to-br from-frontier-blue/0 to-frontier-blue/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative flex items-start gap-6 h-full">
                        <div
                            class="w-14 h-14 bg-frontier-blue/20 border-2 border-frontier-blue/40 rounded-xl flex items-center justify-center shadow-lg shadow-frontier-blue/20 shrink-0"
                        >
                            <span
                                class="text-2xl font-bold bg-brand-gradient text-transparent bg-clip-text"
                                >04</span
                            >
                        </div>
                        <div class="flex flex-col">
                            <h4
                                class="text-xl font-bold text-frontier-light group-hover:text-frontier-blue transition-colors mb-2"
                            >
                                Integración de Sistemas
                            </h4>
                            <p class="text-frontier-light/70">
                                Conectamos sistemas heredados con plataformas
                                modernas, migraciones complejas y sincronización
                                en tiempo real.
                            </p>
                            <div
                                class="h-1 w-0 group-hover:w-full bg-brand-gradient rounded-full transition-all duration-700 mt-auto"
                            >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 5: DevOps (estándar) -->
                <div
                    class="bento-card group relative bg-frontier-dark/40 border border-frontier-cyan/20 rounded-2xl p-8 hover:border-frontier-cyan/50 transition-all duration-500 hover:shadow-xl hover:shadow-frontier-cyan/10 overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-linear-to-br from-frontier-cyan/0 to-frontier-cyan/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative flex flex-col h-full">
                        <div class="flex items-center gap-4 mb-4">
                            <div
                                class="w-14 h-14 bg-frontier-cyan/20 border-2 border-frontier-cyan/40 rounded-xl flex items-center justify-center shadow-lg shadow-frontier-cyan/20"
                            >
                                <span
                                    class="text-2xl font-bold bg-brand-gradient text-transparent bg-clip-text"
                                    >05</span
                                >
                            </div>
                            <h4
                                class="text-xl font-bold text-frontier-light group-hover:text-frontier-cyan transition-colors"
                            >
                                DevOps y CI/CD
                            </h4>
                        </div>
                        <p class="text-frontier-light/70 flex-1">
                            Pipelines automatizados, despliegues continuos,
                            monitoreo de performance y gestión de
                            infraestructura como código.
                        </p>
                        <div
                            class="h-1 w-0 group-hover:w-full bg-brand-gradient rounded-full transition-all duration-700 mt-4"
                        >
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 6: Escalabilidad (estándar) -->
                <div
                    class="bento-card group relative bg-frontier-dark/40 border border-frontier-blue/20 rounded-2xl p-8 hover:border-frontier-blue/50 transition-all duration-500 hover:shadow-xl hover:shadow-frontier-blue/10 overflow-hidden"
                >
                    <div
                        class="absolute inset-0 bg-linear-to-br from-frontier-blue/0 to-frontier-blue/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    >
                    </div>
                    <div class="relative flex flex-col h-full">
                        <div class="flex items-center gap-4 mb-4">
                            <div
                                class="w-14 h-14 bg-frontier-blue/20 border-2 border-frontier-blue/40 rounded-xl flex items-center justify-center shadow-lg shadow-frontier-blue/20"
                            >
                                <span
                                    class="text-2xl font-bold bg-brand-gradient text-transparent bg-clip-text"
                                    >06</span
                                >
                            </div>
                            <h4
                                class="text-xl font-bold text-frontier-light group-hover:text-frontier-blue transition-colors"
                            >
                                Escalabilidad y Performance
                            </h4>
                        </div>
                        <p class="text-frontier-light/70 flex-1">
                            Arquitecturas optimizadas para crecimiento
                            exponencial, balanceo de carga y bases de datos
                            distribuidas de alto rendimiento.
                        </p>
                        <div
                            class="h-1 w-0 group-hover:w-full bg-brand-gradient rounded-full transition-all duration-700 mt-4"
                        >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</Section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const ctx = gsap.context(() => {
            const cards = gsap.utils.toArray(".bento-card");
            cards.forEach((card, i) => {
                gsap.from(card, {
                    scrollTrigger: {
                        trigger: card,
                        start: "top 85%",
                    },
                    y: 60,
                    opacity: 0,
                    duration: 0.8,
                    delay: i * 0.1,
                    ease: "power2.out",
                });
            });

            document.querySelectorAll(".bento-card").forEach((card) => {
                card.addEventListener("mousemove", (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    card.style.setProperty("--mouse-x", `${x}px`);
                    card.style.setProperty("--mouse-y", `${y}px`);
                });
            });
        }, "#capabilities");
    });
</script>

<style>
    .bento-card::before {
        content: "";
        position: absolute;
        top: var(--mouse-y, 50%);
        left: var(--mouse-x, 50%);
        width: 200px;
        height: 200px;
        background: radial-gradient(
            circle,
            rgba(42, 209, 201, 0.08),
            transparent 70%
        );
        transform: translate(-50%, -50%);
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s;
    }
    .bento-card:hover::before {
        opacity: 1;
    }
</style>
