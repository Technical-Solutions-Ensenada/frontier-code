---
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
---

<Section id="about" background="dark" class="!pt-0">
  <Container>
    <div class="relative py-20 sm:py-28 lg:py-36">
      <div class="relative max-w-6xl mx-auto">
        <div
          class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-center"
        >
          <!-- Content Column -->
          <div class="lg:col-span-3 space-y-8">
            <h2
              class="text-4xl sm:text-5xl lg:text-6xl font-light text-frontier-light leading-tight"
            >
              Más que código,<br />
              <span
                class="font-normal bg-linear-to-r from-frontier-cyan to-frontier-blue text-transparent bg-clip-text"
              >
                construimos soluciones
              </span>
            </h2>

            <div
              class="space-y-5 text-lg text-frontier-light/70 leading-relaxed"
            >
              <p>
                Fundada con la visión de
                <strong class="text-frontier-light"
                  >transformar negocios a través del software</strong
                >, Frontier Code desarrolla soluciones tecnológicas de alto
                impacto.
              </p>
              <p>
                Combinamos excelencia técnica con estrategia empresarial para
                generar
                <span
                  class="bg-linear-to-r from-frontier-cyan to-frontier-blue text-transparent bg-clip-text font-semibold"
                  >valor real</span
                >.
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-4 pt-4">
              <a
                href="#contact"
                class="group relative inline-flex items-center gap-2 px-6 py-3 bg-linear-to-r from-frontier-cyan to-frontier-blue text-white font-semibold rounded-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-frontier-cyan/50"
              >
                <span class="relative">Trabajemos juntos</span>
                <svg
                  class="relative w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
              <a
                href="#services"
                class="inline-flex items-center gap-2 px-6 py-3 border-2 border-frontier-cyan/50 text-frontier-cyan font-semibold rounded-lg hover:bg-frontier-cyan/10 hover:border-frontier-cyan transition-all duration-300 hover:scale-105"
              >
                Ver servicios
              </a>
            </div>
          </div>

          <!-- Stats Column -->
          <div class="lg:col-span-2">
            <div class="grid grid-cols-2 gap-6">
              <div
                class="stat-item bg-frontier-dark/50 border border-frontier-cyan/20 rounded-2xl p-6 hover:shadow-lg hover:shadow-frontier-cyan/20 hover:scale-105 hover:border-frontier-cyan/40 transition-all duration-300"
              >
                <div
                  class="text-5xl font-bold bg-linear-to-r from-frontier-cyan to-frontier-blue text-transparent bg-clip-text mb-2"
                >
                  20+
                </div>
                <div
                  class="text-sm font-semibold text-frontier-light uppercase tracking-wide"
                >
                  Proyectos
                </div>
                <div class="text-xs text-frontier-light/50 mt-1">
                  Completados con éxito
                </div>
                <div
                  class="mt-3 w-12 h-1 bg-linear-to-r from-frontier-cyan to-frontier-blue rounded-full"
                >
                </div>
              </div>

              <div
                class="stat-item bg-frontier-dark/50 border border-frontier-blue/20 rounded-2xl p-6 hover:shadow-lg hover:shadow-frontier-blue/20 hover:scale-105 hover:border-frontier-blue/40 transition-all duration-300"
                style="animation-delay: 0.1s;"
              >
                <div
                  class="text-5xl font-bold bg-linear-to-r from-frontier-blue to-frontier-cyan text-transparent bg-clip-text mb-2"
                >
                  5+
                </div>
                <div
                  class="text-sm font-semibold text-frontier-light uppercase tracking-wide"
                >
                  Años Exp.
                </div>
                <div class="text-xs text-frontier-light/50 mt-1">
                  Transformando negocios
                </div>
                <div
                  class="mt-3 w-12 h-1 bg-linear-to-r from-frontier-blue to-frontier-cyan rounded-full"
                >
                </div>
              </div>

              <div
                class="stat-item bg-frontier-dark/50 border border-frontier-cyan/20 rounded-2xl p-6 hover:shadow-lg hover:shadow-frontier-cyan/20 hover:scale-105 hover:border-frontier-cyan/40 transition-all duration-300"
                style="animation-delay: 0.2s;"
              >
                <div
                  class="text-5xl font-bold bg-linear-to-r from-frontier-cyan to-frontier-blue text-transparent bg-clip-text mb-2"
                >
                  10+
                </div>
                <div
                  class="text-sm font-semibold text-frontier-light uppercase tracking-wide"
                >
                  Clientes
                </div>
                <div class="text-xs text-frontier-light/50 mt-1">
                  Satisfechos
                </div>
                <div
                  class="mt-3 w-12 h-1 bg-linear-to-r from-frontier-cyan to-frontier-blue rounded-full"
                >
                </div>
              </div>

              <div
                class="stat-item bg-frontier-dark/50 border border-frontier-blue/20 rounded-2xl p-6 hover:shadow-lg hover:shadow-frontier-blue/20 hover:scale-105 hover:border-frontier-blue/40 transition-all duration-300"
                style="animation-delay: 0.3s;"
              >
                <div
                  class="text-5xl font-bold bg-linear-to-r from-frontier-blue to-frontier-cyan text-transparent bg-clip-text mb-2"
                >
                  6+
                </div>
                <div
                  class="text-sm font-semibold text-frontier-light uppercase tracking-wide"
                >
                  Expertos
                </div>
                <div class="text-xs text-frontier-light/50 mt-1">
                  En el equipo
                </div>
                <div
                  class="mt-3 w-12 h-1 bg-linear-to-r from-frontier-blue to-frontier-cyan rounded-full"
                >
                </div>
              </div>
            </div>

            <div
              class="mt-6 p-4 bg-frontier-dark/50 border border-frontier-cyan/20 rounded-xl hover:border-frontier-cyan/40 transition-all duration-300"
            >
              <div class="flex items-center gap-3">
                <div class="shrink-0">
                  <svg
                    class="w-8 h-8 text-frontier-cyan"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-frontier-light">
                    Calidad garantizada
                  </div>
                  <div class="text-xs text-frontier-light/60">
                    Soluciones probadas y confiables
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>

<style>
  #about {
    scroll-margin-top: 100px;
  }

  .stat-item {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
    animation-play-state: paused;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function initStatsAnimation() {
    const stats = document.querySelectorAll(".stat-item");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.style.animationPlayState = "running";
          }
        });
      },
      { threshold: 0.2 },
    );
    stats.forEach((stat) => observer.observe(stat));
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initStatsAnimation);
  } else {
    initStatsAnimation();
  }

  document.addEventListener("astro:page-load", initStatsAnimation);
</script>
