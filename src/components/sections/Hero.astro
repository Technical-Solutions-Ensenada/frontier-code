---
import Container from "../ui/Container.astro";
import HeroSoftware from "../ui/HeroSoftware.astro";
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-frontier-dark"
>
  <Container>
    <div
      class="relative z-10 grid lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto"
    >
      <!-- Left Content -->
      <div class="text-center lg:text-left order-2 lg:order-1">
        <!-- Headline with Dynamic Text -->
        <h1
          class="font-monda text-4xl sm:text-5xl lg:text-6xl font-light text-frontier-light mb-6 leading-tight"
        >
          Creamos
          <span class="block mt-2">
            <span
              id="dynamic-word"
              class="text-transparent bg-linear-to-r from-frontier-cyan to-frontier-blue bg-clip-text font-semibold"
            ></span>
            <span
              id="word-cursor"
              class="inline-block w-1 h-12 sm:h-14 bg-frontier-cyan ml-1 animate-blink align-middle"
            ></span>
          </span>
        </h1>

        <!-- Subtitle -->
        <p
          class="font-nunito text-lg sm:text-xl text-dark-300 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed"
        >
          Transformamos visiones ambiciosas en soluciones digitales. Código
          limpio, arquitectura sólida y experiencias que impresionan.
        </p>

        <!-- CTA Buttons -->
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-12"
        >
          <a
            href="#contact"
            class="group relative px-8 py-4 bg-linear-to-r from-frontier-blue to-frontier-cyan text-white font-semibold rounded-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-frontier-blue/25"
          >
            <div
              class="absolute inset-0 bg-linear-to-r from-frontier-cyan to-frontier-blue opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            >
            </div>
            <span class="relative flex items-center justify-center gap-2">
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              <span id="dynamic-cta">Impulsa Tu Eficiencia</span>
            </span>
          </a>

          <a
            href="#services"
            class="px-8 py-4 border-2 border-frontier-cyan/50 font-semibold rounded-lg hover:bg-frontier-cyan/10 hover:border-frontier-cyan hover:text-frontier-cyan transition-all duration-300 hover:scale-105"
          >
            Ver Servicios
          </a>
        </div>

        <!-- Simplified Features -->
        <div
          class="flex flex-wrap justify-center lg:justify-start gap-6 text-dark-400 text-sm font-nunito"
        >
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-frontier-cyan"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Automatización Inteligente</span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-frontier-blue"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Escalabilidad Total</span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-frontier-cyan"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Resultados Medibles</span>
          </div>
        </div>
      </div>

      <!-- Right Visual -->
      <div
        class="order-1 lg:order-2 pt-30 lg:pt-0 flex justify-center items-center"
      >
        <HeroSoftware />
      </div>
    </div>
  </Container>

  <!-- Scroll Indicator -->
  <div
    class="hidden lg:block absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce"
  >
    <svg
      class="w-6 h-6 text-frontier-cyan/50"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<style>
  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }
  .animate-blink {
    animation: blink 1s infinite;
  }
</style>

<script
  define:vars={{
    words: [
      "eficiencia",
      "automatización",
      "rentabilidad",
      "escalamiento",
      "inteligencia",
      "crecimiento",
      "innovación",
      "transformación",
    ],
  }}
>
  const dynamicWord = document.getElementById("dynamic-word");
  const wordCursor = document.getElementById("word-cursor");
  const dynamicCTA = document.getElementById("dynamic-cta");

  let wordIndex = 0;
  let charIndexWord = 0;
  let isDeletingWord = false;

  const ctaPhrases = [
    "Impulsa Tu Eficiencia",
    "Maximiza Resultados Hoy",
    "Escala Tu Operación",
    "Automatiza Procesos Ya",
  ];

  const randomCTAIndex = Math.floor(Math.random() * ctaPhrases.length);
  dynamicCTA.textContent = ctaPhrases[randomCTAIndex];

  function typeDynamicWord() {
    const currentWord = words[wordIndex];

    if (!isDeletingWord) {
      dynamicWord.textContent = currentWord.substring(0, charIndexWord + 1);
      charIndexWord++;

      if (charIndexWord === currentWord.length) {
        setTimeout(() => {
          isDeletingWord = true;
          setTimeout(typeDynamicWord, 2000);
        }, 2000);
        return;
      }
    } else {
      dynamicWord.textContent = currentWord.substring(0, charIndexWord - 1);
      charIndexWord--;

      if (charIndexWord === 0) {
        isDeletingWord = false;
        wordIndex = (wordIndex + 1) % words.length;
        setTimeout(typeDynamicWord, 500);
        return;
      }
    }

    setTimeout(typeDynamicWord, isDeletingWord ? 50 : 100);
  }

  setTimeout(() => {
    typeDynamicWord();
  }, 2500);
</script>
