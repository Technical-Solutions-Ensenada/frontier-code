---
// src/components/SoftwareMockupVisual.astro
---

<div
    class="mockup-visual relative w-full max-w-2xl aspect-16/10 mx-auto"
    id="mockupContainer"
>
    <svg
        id="mockupSvg"
        viewBox="0 0 800 500"
        class="w-full h-full overflow-visible"
        xmlns="http://www.w3.org/2000/svg"
    >
        <defs>
            <!-- Gradientes actualizados con la paleta del cliente -->
            <linearGradient id="barGrad" x1="0" y1="1" x2="0" y2="0">
                <stop offset="0%" stop-color="#2AD1C9" stop-opacity="0.3"
                ></stop>
                <!-- cyan -->
                <stop offset="100%" stop-color="#2AD1C9" stop-opacity="0.9"
                ></stop>
            </linearGradient>
            <linearGradient id="barGradAlt" x1="0" y1="1" x2="0" y2="0">
                <stop offset="0%" stop-color="#0862C8" stop-opacity="0.3"
                ></stop>
                <!-- blue -->
                <stop offset="100%" stop-color="#0862C8" stop-opacity="0.9"
                ></stop>
            </linearGradient>
            <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#2AD1C9" stop-opacity="0"></stop>
                <stop offset="50%" stop-color="#2AD1C9" stop-opacity="0.8"
                ></stop>
                <stop offset="100%" stop-color="#2AD1C9" stop-opacity="0"
                ></stop>
            </linearGradient>

            <!-- Filtro glow -->
            <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
                <feMerge>
                    <feMergeNode in="blur"></feMergeNode>
                    <feMergeNode in="SourceGraphic"></feMergeNode>
                </feMerge>
            </filter>
        </defs>

        <!-- ========== FONDO DEL DASHBOARD (BLANCO) ========== -->
        <rect x="20" y="20" width="760" height="460" rx="12" fill="#ffffff"
        ></rect>

        <!-- ========== BORDE DEL MONITOR ========== -->
        <rect
            x="20"
            y="20"
            width="760"
            height="460"
            rx="12"
            fill="none"
            stroke="#DEE6EC"
            stroke-width="2"
            class="monitor-frame"></rect>

        <!-- ========== BARRA SUPERIOR (header) ========== -->
        <g id="topBar">
            <rect x="20" y="20" width="760" height="56" rx="12" fill="#f8fafc"
            ></rect>
            <rect x="20" y="48" width="760" height="28" fill="#f8fafc"></rect>
            <line
                x1="20"
                y1="76"
                x2="780"
                y2="76"
                stroke="#DEE6EC"
                stroke-width="1"></line>

            <!-- Botones de ventana macOS -->
            <circle cx="40" cy="48" r="7" fill="#FF5F57"></circle>
            <!-- Rojo -->
            <circle cx="60" cy="48" r="7" fill="#FFBD2E"></circle>
            <!-- Amarillo -->
            <circle cx="80" cy="48" r="7" fill="#27C93F"></circle>
            <!-- Verde -->

            <!-- Logo esqueleto -->
            <rect x="110" y="38" width="20" height="20" rx="4" fill="#DEE6EC"
            ></rect>
            <rect x="138" y="42" width="60" height="12" rx="3" fill="#DEE6EC"
            ></rect>

            <!-- Menú horizontal -->
            <rect x="240" y="42" width="40" height="10" rx="2" fill="#DEE6EC"
            ></rect>
            <rect x="300" y="42" width="50" height="10" rx="2" fill="#DEE6EC"
            ></rect>
            <rect x="370" y="42" width="45" height="10" rx="2" fill="#DEE6EC"
            ></rect>

            <!-- Iconos derecha -->
            <circle cx="730" cy="48" r="8" fill="#DEE6EC"></circle>
            <circle cx="700" cy="48" r="8" fill="#DEE6EC"></circle>
        </g>

        <!-- ========== SIDEBAR IZQUIERDO ========== -->
        <g id="sidebar">
            <rect x="20" y="76" width="160" height="354" rx="0" fill="#f8fafc"
            ></rect>
            <line
                x1="180"
                y1="76"
                x2="180"
                y2="430"
                stroke="#DEE6EC"
                stroke-width="1"></line>

            <!-- Ítems del menú -->
            <rect x="40" y="100" width="120" height="8" rx="2" fill="#DEE6EC"
            ></rect>
            <rect
                x="40"
                y="125"
                width="100"
                height="8"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <rect
                x="40"
                y="150"
                width="115"
                height="8"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <rect
                x="40"
                y="175"
                width="90"
                height="8"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <rect
                x="40"
                y="200"
                width="125"
                height="8"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <line
                x1="40"
                y1="230"
                x2="160"
                y2="230"
                stroke="#DEE6EC"
                stroke-width="1"></line>
            <rect
                x="40"
                y="250"
                width="110"
                height="8"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <rect
                x="40"
                y="275"
                width="95"
                height="8"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
        </g>

        <!-- ========== ÁREA PRINCIPAL ========== -->
        <!-- Rejilla de fondo -->
        <g id="chartGrid" opacity="0.5">
            <line
                x1="210"
                y1="140"
                x2="500"
                y2="140"
                stroke="#DEE6EC"
                stroke-width="1"></line>
            <line
                x1="210"
                y1="190"
                x2="500"
                y2="190"
                stroke="#DEE6EC"
                stroke-width="1"></line>
            <line
                x1="210"
                y1="240"
                x2="500"
                y2="240"
                stroke="#DEE6EC"
                stroke-width="1"></line>
            <line
                x1="210"
                y1="290"
                x2="500"
                y2="290"
                stroke="#DEE6EC"
                stroke-width="1"></line>
            <line
                x1="210"
                y1="340"
                x2="500"
                y2="340"
                stroke="#DEE6EC"
                stroke-width="1"></line>
        </g>

        <!-- Gráfico de barras -->
        <g id="barChart">
            <line
                x1="210"
                y1="380"
                x2="500"
                y2="380"
                stroke="#DEE6EC"
                stroke-width="1"></line>
            <line
                x1="210"
                y1="110"
                x2="210"
                y2="380"
                stroke="#DEE6EC"
                stroke-width="1"></line>

            <rect
                x="230"
                y="300"
                width="25"
                height="80"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-1"></rect>
            <rect
                x="270"
                y="240"
                width="25"
                height="140"
                rx="3"
                fill="url(#barGradAlt)"
                class="bar bar-2"></rect>
            <rect
                x="310"
                y="200"
                width="25"
                height="180"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-3"></rect>
            <rect
                x="350"
                y="260"
                width="25"
                height="120"
                rx="3"
                fill="url(#barGradAlt)"
                class="bar bar-4"></rect>
            <rect
                x="390"
                y="170"
                width="25"
                height="210"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-5"></rect>
            <rect
                x="430"
                y="230"
                width="25"
                height="150"
                rx="3"
                fill="url(#barGradAlt)"
                class="bar bar-6"></rect>
            <rect
                x="470"
                y="280"
                width="25"
                height="100"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-7"></rect>
        </g>

        <!-- Línea de tendencia -->
        <g id="lineChart">
            <polyline
                points="230,260 290,220 350,190 410,170 470,140"
                fill="none"
                stroke="#0862C8"
                stroke-width="2"
                stroke-dasharray="4 3"
                class="trend-line"></polyline>
            <circle
                cx="230"
                cy="260"
                r="3"
                fill="#0862C8"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="290"
                cy="220"
                r="3"
                fill="#0862C8"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="350"
                cy="190"
                r="3"
                fill="#0862C8"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="410"
                cy="170"
                r="3"
                fill="#0862C8"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="470"
                cy="140"
                r="3"
                fill="#0862C8"
                opacity="0.8"
                class="trend-dot"></circle>
        </g>

        <!-- Tabla de datos -->
        <g id="dataTable">
            <rect x="210" y="405" width="320" height="20" rx="4" fill="#f8fafc"
            ></rect>
            <rect x="220" y="410" width="70" height="8" rx="2" fill="#DEE6EC"
            ></rect>
            <rect x="320" y="410" width="50" height="8" rx="2" fill="#DEE6EC"
            ></rect>
            <rect x="400" y="410" width="50" height="8" rx="2" fill="#DEE6EC"
            ></rect>
            <rect x="480" y="410" width="40" height="8" rx="2" fill="#DEE6EC"
            ></rect>

            <rect
                x="220"
                y="435"
                width="100"
                height="6"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <rect
                x="340"
                y="435"
                width="60"
                height="6"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <rect
                x="420"
                y="435"
                width="60"
                height="6"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>
            <rect
                x="500"
                y="435"
                width="20"
                height="6"
                rx="2"
                fill="#DEE6EC"
                opacity="0.5"></rect>

            <rect
                x="220"
                y="450"
                width="90"
                height="6"
                rx="2"
                fill="#DEE6EC"
                opacity="0.3"></rect>
            <rect
                x="340"
                y="450"
                width="70"
                height="6"
                rx="2"
                fill="#DEE6EC"
                opacity="0.3"></rect>
            <rect
                x="420"
                y="450"
                width="40"
                height="6"
                rx="2"
                fill="#DEE6EC"
                opacity="0.3"></rect>
        </g>

        <!-- Cursor animado -->
        <circle
            cx="0"
            cy="0"
            r="5"
            fill="#ffffff"
            filter="url(#glow)"
            class="cursor-glow"
            opacity="0"></circle>

        <!-- Puntos de estado -->
        <circle cx="760" cy="478" r="3" fill="#2AD1C9" class="status-dot"
        ></circle>
        <circle cx="30" cy="478" r="3" fill="#2AD1C9" class="status-dot"
        ></circle>
    </svg>
</div>

<script>
    import gsap from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        const ctx = gsap.context(() => {
            const tl = gsap.timeline({ defaults: { ease: "power2.inOut" } });

            tl.fromTo(
                ".bar",
                { scaleY: 0, transformOrigin: "bottom" },
                {
                    scaleY: 1,
                    duration: 0.8,
                    stagger: { each: 0.1 },
                    ease: "back.out(1.2)",
                },
                "+=0.3",
            );

            tl.fromTo(
                ".trend-line",
                { strokeDashoffset: 400, strokeDasharray: 400 },
                { strokeDashoffset: 0, duration: 1.2, ease: "power2.inOut" },
                "-=0.5",
            );

            tl.fromTo(
                ".trend-dot",
                { scale: 0, opacity: 0 },
                {
                    scale: 1,
                    opacity: 0.8,
                    duration: 0.3,
                    stagger: 0.1,
                    ease: "back.out(2)",
                },
                "-=0.8",
            );

            tl.fromTo(
                "#dataTable rect:not(:first-child)",
                { opacity: 0, x: -10 },
                { opacity: 1, x: 0, duration: 0.4, stagger: 0.05 },
                "-=0.2",
            );

            tl.fromTo(
                "#sidebar rect:not(:first-child):not(:nth-child(2)), #sidebar line",
                { opacity: 0, x: -20 },
                { opacity: 1, x: 0, duration: 0.4, stagger: 0.05 },
                "-=0.3",
            );

            gsap.to(".cursor-glow", {
                duration: 5,
                repeat: -1,
                ease: "none",
                motionPath: {
                    path: [
                        { x: 240, y: 300 },
                        { x: 280, y: 240 },
                        { x: 320, y: 200 },
                        { x: 360, y: 260 },
                        { x: 400, y: 170 },
                        { x: 440, y: 230 },
                        { x: 480, y: 280 },
                        { x: 480, y: 440 },
                        { x: 230, y: 440 },
                        { x: 230, y: 120 },
                        { x: 50, y: 270 },
                        { x: 730, y: 48 },
                        { x: 240, y: 300 },
                    ],
                    curviness: 2,
                    autoRotate: false,
                },
                onStart: () =>
                    gsap.to(".cursor-glow", { opacity: 0.8, duration: 0.3 }),
            });

            gsap.to(".status-dot", {
                scale: 1.5,
                opacity: 0.3,
                duration: 1.5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });

            gsap.to(".monitor-frame", {
                strokeOpacity: 0.7,
                duration: 3,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
        }, "#mockupContainer");
    });
</script>

<style>
    .mockup-visual {
        background: transparent;
    }
    .mockup-visual svg {
        display: block;
    }
</style>
