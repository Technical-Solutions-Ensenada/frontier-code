---
// src/components/SoftwareMockupVisual.astro
---

<div
    class="mockup-visual relative w-full max-w-2xl aspect-16/10 mx-auto"
    id="mockupContainer"
>
    <svg
        id="mockupSvg"
        viewBox="0 0 800 500"
        class="w-full h-full overflow-visible"
        xmlns="http://www.w3.org/2000/svg"
    >
        <defs>
            <!-- Gradientes -->
            <linearGradient id="barGrad" x1="0" y1="1" x2="0" y2="0">
                <stop offset="0%" stop-color="#06b6d4" stop-opacity="0.3"
                ></stop>
                <stop offset="100%" stop-color="#06b6d4" stop-opacity="0.9"
                ></stop>
            </linearGradient>
            <linearGradient id="barGradAlt" x1="0" y1="1" x2="0" y2="0">
                <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3"
                ></stop>
                <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.9"
                ></stop>
            </linearGradient>
            <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#06b6d4" stop-opacity="0"></stop>
                <stop offset="50%" stop-color="#06b6d4" stop-opacity="0.8"
                ></stop>
                <stop offset="100%" stop-color="#06b6d4" stop-opacity="0"
                ></stop>
            </linearGradient>

            <!-- Filtro glow -->
            <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
                <feMerge>
                    <feMergeNode in="blur"></feMergeNode>
                    <feMergeNode in="SourceGraphic"></feMergeNode>
                </feMerge>
            </filter>
        </defs>

        <!-- Fondo transparente, sin rectángulo de fondo -->

        <!-- ========== BORDE DEL MONITOR ========== -->
        <rect
            x="20"
            y="20"
            width="760"
            height="460"
            rx="12"
            fill="none"
            stroke="rgba(6, 182, 212, 0.15)"
            stroke-width="2"
            class="monitor-frame"></rect>

        <!-- ========== BARRA SUPERIOR (header) ========== -->
        <g id="topBar">
            <!-- Logo esqueleto -->
            <rect
                x="40"
                y="38"
                width="20"
                height="20"
                rx="4"
                fill="rgba(6, 182, 212, 0.2)"></rect>
            <rect
                x="68"
                y="42"
                width="60"
                height="12"
                rx="3"
                fill="rgba(6, 182, 212, 0.15)"></rect>
            <!-- Menú horizontal -->
            <rect
                x="200"
                y="42"
                width="40"
                height="10"
                rx="2"
                fill="rgba(6, 182, 212, 0.12)"></rect>
            <rect
                x="260"
                y="42"
                width="50"
                height="10"
                rx="2"
                fill="rgba(6, 182, 212, 0.12)"></rect>
            <rect
                x="330"
                y="42"
                width="45"
                height="10"
                rx="2"
                fill="rgba(6, 182, 212, 0.12)"></rect>
            <!-- Iconos derecha -->
            <circle cx="730" cy="48" r="8" fill="rgba(6, 182, 212, 0.12)"
            ></circle>
            <circle cx="700" cy="48" r="8" fill="rgba(6, 182, 212, 0.12)"
            ></circle>
        </g>

        <!-- ========== SIDEBAR IZQUIERDO ========== -->
        <g id="sidebar">
            <rect
                x="40"
                y="100"
                width="140"
                height="340"
                rx="8"
                fill="rgba(6, 182, 212, 0.04)"></rect>
            <!-- Ítems del menú -->
            <rect
                x="55"
                y="120"
                width="110"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.15)"></rect>
            <rect
                x="55"
                y="145"
                width="90"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <rect
                x="55"
                y="170"
                width="105"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <rect
                x="55"
                y="195"
                width="80"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <rect
                x="55"
                y="220"
                width="115"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <!-- Separador -->
            <line
                x1="55"
                y1="250"
                x2="165"
                y2="250"
                stroke="rgba(6, 182, 212, 0.08)"
                stroke-width="1"></line>
            <rect
                x="55"
                y="270"
                width="100"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <rect
                x="55"
                y="295"
                width="85"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
        </g>

        <!-- ========== ÁREA PRINCIPAL ========== -->
        <!-- Gráfico de barras (skeleton) -->
        <g id="barChart">
            <!-- Ejes -->
            <line
                x1="220"
                y1="380"
                x2="500"
                y2="380"
                stroke="rgba(6, 182, 212, 0.2)"
                stroke-width="1"></line>
            <line
                x1="220"
                y1="120"
                x2="220"
                y2="380"
                stroke="rgba(6, 182, 212, 0.2)"
                stroke-width="1"></line>

            <!-- Barras (animadas con GSAP) -->
            <rect
                x="240"
                y="300"
                width="25"
                height="80"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-1"></rect>
            <rect
                x="280"
                y="240"
                width="25"
                height="140"
                rx="3"
                fill="url(#barGradAlt)"
                class="bar bar-2"></rect>
            <rect
                x="320"
                y="200"
                width="25"
                height="180"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-3"></rect>
            <rect
                x="360"
                y="260"
                width="25"
                height="120"
                rx="3"
                fill="url(#barGradAlt)"
                class="bar bar-4"></rect>
            <rect
                x="400"
                y="170"
                width="25"
                height="210"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-5"></rect>
            <rect
                x="440"
                y="230"
                width="25"
                height="150"
                rx="3"
                fill="url(#barGradAlt)"
                class="bar bar-6"></rect>
            <rect
                x="480"
                y="280"
                width="25"
                height="100"
                rx="3"
                fill="url(#barGrad)"
                class="bar bar-7"></rect>
        </g>

        <!-- Línea de tendencia (gráfico lineal esqueleto) -->
        <g id="lineChart">
            <polyline
                points="240,260 300,220 360,190 420,170 480,140"
                fill="none"
                stroke="rgba(139, 92, 246, 0.4)"
                stroke-width="2"
                stroke-dasharray="4 3"
                class="trend-line"></polyline>
            <!-- Puntos en la línea -->
            <circle
                cx="240"
                cy="260"
                r="3"
                fill="#8b5cf6"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="300"
                cy="220"
                r="3"
                fill="#8b5cf6"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="360"
                cy="190"
                r="3"
                fill="#8b5cf6"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="420"
                cy="170"
                r="3"
                fill="#8b5cf6"
                opacity="0.8"
                class="trend-dot"></circle>
            <circle
                cx="480"
                cy="140"
                r="3"
                fill="#8b5cf6"
                opacity="0.8"
                class="trend-dot"></circle>
        </g>

        <!-- Tabla de datos esqueleto -->
        <g id="dataTable">
            <!-- Cabecera -->
            <rect
                x="220"
                y="410"
                width="320"
                height="20"
                rx="4"
                fill="rgba(6, 182, 212, 0.08)"></rect>
            <rect
                x="230"
                y="415"
                width="70"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.15)"></rect>
            <rect
                x="320"
                y="415"
                width="50"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.15)"></rect>
            <rect
                x="400"
                y="415"
                width="50"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.15)"></rect>
            <rect
                x="480"
                y="415"
                width="50"
                height="8"
                rx="2"
                fill="rgba(6, 182, 212, 0.15)"></rect>
            <!-- Filas -->
            <rect
                x="230"
                y="440"
                width="100"
                height="6"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <rect
                x="350"
                y="440"
                width="60"
                height="6"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <rect
                x="430"
                y="440"
                width="60"
                height="6"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>
            <rect
                x="510"
                y="440"
                width="20"
                height="6"
                rx="2"
                fill="rgba(6, 182, 212, 0.1)"></rect>

            <rect
                x="230"
                y="455"
                width="90"
                height="6"
                rx="2"
                fill="rgba(6, 182, 212, 0.06)"></rect>
            <rect
                x="350"
                y="455"
                width="70"
                height="6"
                rx="2"
                fill="rgba(6, 182, 212, 0.06)"></rect>
            <rect
                x="430"
                y="455"
                width="40"
                height="6"
                rx="2"
                fill="rgba(6, 182, 212, 0.06)"></rect>
        </g>

        <!-- Elemento flotante: cursor o destello animado -->
        <circle
            cx="0"
            cy="0"
            r="5"
            fill="#ffffff"
            filter="url(#glow)"
            class="cursor-glow"
            opacity="0"></circle>

        <!-- Pequeños puntos de estado (online, actividad) -->
        <circle cx="760" cy="460" r="4" fill="#06b6d4" class="status-dot"
        ></circle>
        <circle cx="30" cy="460" r="4" fill="#06b6d4" class="status-dot"
        ></circle>
    </svg>
</div>

<script>
    import gsap from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        const ctx = gsap.context(() => {
            const tl = gsap.timeline({ defaults: { ease: "power2.inOut" } });

            // 1. Barras del gráfico: desde altura 0 hasta su altura real
            tl.fromTo(
                ".bar",
                { scaleY: 0, transformOrigin: "bottom" },
                {
                    scaleY: 1,
                    duration: 0.8,
                    stagger: { each: 0.1 },
                    ease: "back.out(1.2)",
                },
                "+=0.3",
            );

            // 2. Línea de tendencia: dibujo progresivo con stroke-dasharray
            tl.fromTo(
                ".trend-line",
                { strokeDashoffset: 400, strokeDasharray: 400 },
                { strokeDashoffset: 0, duration: 1.2, ease: "power2.inOut" },
                "-=0.5",
            );

            // 3. Puntos de la tendencia: aparecen con pop
            tl.fromTo(
                ".trend-dot",
                { scale: 0, opacity: 0 },
                {
                    scale: 1,
                    opacity: 0.8,
                    duration: 0.3,
                    stagger: 0.1,
                    ease: "back.out(2)",
                },
                "-=0.8",
            );

            // 4. Tabla: filas aparecen secuencialmente
            tl.fromTo(
                "#dataTable rect:not(:first-child)",
                { opacity: 0, x: -10 },
                { opacity: 1, x: 0, duration: 0.4, stagger: 0.05 },
                "-=0.2",
            );

            // 5. Sidebar: items con fade desde izquierda
            tl.fromTo(
                "#sidebar rect:not(:first-child), #sidebar line",
                { opacity: 0, x: -20 },
                { opacity: 1, x: 0, duration: 0.4, stagger: 0.05 },
                "-=0.3",
            );

            // 6. Cursor brillante que recorre la interfaz
            gsap.to(".cursor-glow", {
                duration: 5,
                repeat: -1,
                ease: "none",
                motionPath: {
                    path: [
                        { x: 240, y: 300 },
                        { x: 280, y: 240 },
                        { x: 320, y: 200 },
                        { x: 360, y: 260 },
                        { x: 400, y: 170 },
                        { x: 440, y: 230 },
                        { x: 480, y: 280 },
                        { x: 480, y: 440 },
                        { x: 230, y: 440 },
                        { x: 230, y: 120 },
                        { x: 50, y: 270 },
                        { x: 730, y: 48 },
                        { x: 240, y: 300 },
                    ],
                    curviness: 2,
                    autoRotate: false,
                },
                onStart: () =>
                    gsap.to(".cursor-glow", { opacity: 0.8, duration: 0.3 }),
            });

            // 7. Puntos de estado (latido)
            gsap.to(".status-dot", {
                scale: 1.5,
                opacity: 0.3,
                duration: 1.5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });

            // 8. Marco del monitor: pulso sutil
            gsap.to(".monitor-frame", {
                strokeOpacity: 0.3,
                duration: 3,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
        }, "#mockupContainer");
    });
</script>

<style>
    .mockup-visual {
        background: transparent;
    }
    .mockup-visual svg {
        display: block;
    }
</style>
