---
// HeroQuantum.astro
---

<section class="hero-quantum" id="hero">
    <canvas id="quantumCanvas" aria-hidden="true"></canvas>

    <!-- Botón inicial centrado sobre la esfera -->
    <button class="init-btn" id="initBtn">Iniciar Proyecto</button>

    <!-- Contenido textual (oculto hasta la explosión) -->
    <div class="hero-content" id="heroContent">
        <h1>
            Creamos el<br />
            <span class="highlight">Futuro Digital</span>
        </h1>
        <p class="subtitle">
            Transformamos visiones en código limpio y escalable. Especialistas
            en automatización, cloud y arquitectura de alto rendimiento.
        </p>
        <div class="cta-group">
            <a href="#contact" class="btn btn-primary">Impulsa tu eficiencia</a>
            <a href="#services" class="btn btn-secondary">Ver servicios</a>
        </div>
    </div>
</section>

<style>
    :root {
        --dark: #0a0a14;
        --blue: #1e6ef0;
        --cyan: #00e0ff;
        --white: #f0f4ff;
        --gray: #a0aec0;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .hero-quantum {
        position: relative;
        width: 100vw;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--dark);
        overflow: hidden;
    }

    canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: none;
    }

    .init-btn {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 20;
        background: transparent;
        border: 2px solid var(--cyan);
        color: var(--cyan);
        padding: 1rem 2.5rem;
        font-family: "Monda", sans-serif;
        font-size: 1.2rem;
        letter-spacing: 0.1em;
        border-radius: 50px;
        cursor: pointer;
        backdrop-filter: blur(10px);
        background: rgba(10, 10, 20, 0.6);
        transition: all 0.3s;
        text-transform: uppercase;
        box-shadow: 0 0 20px rgba(0, 224, 255, 0.3);
        opacity: 1;
    }

    .init-btn:hover {
        background: var(--cyan);
        color: var(--dark);
        box-shadow: 0 0 40px var(--cyan);
    }

    .init-btn.hidden {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.5s;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        opacity: 0;
        transform: scale(0.8);
        pointer-events: none;
        transition: none; /* GSAP se encarga */
        max-width: 800px;
        padding: 0 2rem;
    }

    .hero-content.visible {
        pointer-events: auto;
    }

    h1 {
        font-family: "Monda", sans-serif;
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 700;
        color: var(--white);
        margin-bottom: 1.5rem;
        line-height: 1.2;
    }

    .highlight {
        background: linear-gradient(135deg, var(--cyan) 0%, var(--blue) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        font-size: clamp(1rem, 2.5vw, 1.25rem);
        color: var(--gray);
        max-width: 600px;
        margin: 0 auto 2.5rem;
        line-height: 1.6;
    }

    .cta-group {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-block;
        padding: 0.9rem 2.2rem;
        border-radius: 40px;
        font-weight: 700;
        text-decoration: none;
        font-size: 1rem;
        letter-spacing: 0.03em;
        transition:
            box-shadow 0.3s,
            transform 0.2s;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--blue), var(--cyan));
        color: var(--dark);
        box-shadow: 0 0 25px rgba(30, 110, 240, 0.5);
    }

    .btn-primary:hover {
        box-shadow: 0 0 50px var(--cyan);
        transform: translateY(-2px);
    }

    .btn-secondary {
        background: transparent;
        border: 2px solid var(--cyan);
        color: var(--cyan);
        backdrop-filter: blur(10px);
    }

    .btn-secondary:hover {
        background: rgba(0, 224, 255, 0.1);
        box-shadow: 0 0 30px var(--cyan);
    }
</style>

<script>
    import gsap from "gsap";

    // ─── Configuración ─────────────────────
    const canvas = document.getElementById("quantumCanvas");
    const ctx = canvas.getContext("2d");
    const initBtn = document.getElementById("initBtn");
    const heroContent = document.getElementById("heroContent");

    let width, height, centerX, centerY;
    const particles = [];
    const PARTICLE_COUNT = 250;
    const EXPLOSION_DURATION = 1.8; // segundos

    let explosionProgress = 0;
    let isExploding = false;
    let rotationAngle = 0;
    const BASE_ROTATION_SPEED = 0.004;

    // Paleta de colores
    const COLORS = [
        "rgba(0, 224, 255, 0.9)", // cian
        "rgba(30, 110, 240, 0.95)", // azul
        "rgba(0, 224, 255, 0.6)",
        "rgba(30, 110, 240, 0.6)",
        "rgba(255, 255, 255, 0.5)",
    ];

    // ─── Partícula ────────────────────────
    class Particle {
        constructor() {
            this.reset();
        }

        reset() {
            // Posición inicial en esfera compacta
            this.theta = Math.random() * Math.PI * 2;
            this.phi = Math.acos(2 * Math.random() - 1);
            this.baseRadius = 60 + Math.random() * 40;

            // Radio final (explosión)
            this.explosionRadius = 350 + Math.random() * 500;

            // Tamaño y opacidad
            this.size = 1.5 + Math.random() * 3.5;
            this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
        }

        getPosition(progress, rotation) {
            const radius =
                this.baseRadius +
                (this.explosionRadius - this.baseRadius) * progress;
            const theta = this.theta + rotation;
            const x3 = radius * Math.sin(this.phi) * Math.cos(theta);
            const y3 = radius * Math.cos(this.phi);
            const z3 = radius * Math.sin(this.phi) * Math.sin(theta);
            return { x: centerX + x3, y: centerY + y3, z: z3 };
        }
    }

    // ─── Inicialización ──────────────────
    function createParticles() {
        particles.length = 0;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
            particles.push(new Particle());
        }
    }

    function resizeCanvas() {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
        centerX = width / 2;
        centerY = height / 2;
        createParticles();
    }

    // ─── Dibujo ──────────────────────────
    function draw() {
        ctx.clearRect(0, 0, width, height);

        // Resplandor central suave
        const glow = ctx.createRadialGradient(
            centerX,
            centerY,
            0,
            centerX,
            centerY,
            width * 0.5,
        );
        glow.addColorStop(0, "rgba(0,224,255,0.07)");
        glow.addColorStop(0.5, "rgba(10,10,20,0.5)");
        glow.addColorStop(1, "#0a0a14");
        ctx.fillStyle = glow;
        ctx.fillRect(0, 0, width, height);

        for (const p of particles) {
            const { x, y, z } = p.getPosition(explosionProgress, rotationAngle);
            const depth = 0.4 + (z / 300) * 0.6;
            const drawSize = p.size * depth * (0.8 + explosionProgress * 1.2);
            const alpha = 0.8 - explosionProgress * 0.8;
            if (alpha <= 0) continue;

            const [r, g, b] = p.color.match(/(\d+)/g).map(Number);
            ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
            ctx.beginPath();
            ctx.arc(x, y, drawSize, 0, Math.PI * 2);
            ctx.fill();

            // Brillo interno
            if (alpha > 0.25) {
                ctx.fillStyle = `rgba(255,255,255,${alpha * 0.5})`;
                ctx.beginPath();
                ctx.arc(x, y, drawSize * 0.4, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        if (!isExploding) {
            rotationAngle += BASE_ROTATION_SPEED;
        }
    }

    function animationLoop() {
        draw();
        requestAnimationFrame(animationLoop);
    }

    // ─── Explosión ────────────────────────
    function triggerExplosion() {
        if (isExploding) return;
        isExploding = true;

        // Ocultar botón
        initBtn.classList.add("hidden");

        // Objeto para animar el progreso
        const explosionObj = { progress: 0 };
        const tl = gsap.timeline({ defaults: { ease: "power2.inOut" } });

        // 1. Expandir partículas
        tl.to(
            explosionObj,
            {
                progress: 1,
                duration: EXPLOSION_DURATION,
                ease: "power3.in",
                onUpdate: () => {
                    explosionProgress = explosionObj.progress;
                },
            },
            0,
        );

        // 2. Revelar contenido textual con un rebote
        tl.to(
            heroContent,
            {
                opacity: 1,
                scale: 1,
                duration: 1,
                ease: "back.out(1.7)",
                onStart: () => heroContent.classList.add("visible"),
            },
            "-=0.4",
        );

        // 3. Desvanecer el canvas para que el foco pase al texto
        tl.to(
            canvas,
            {
                opacity: 0,
                duration: 1,
                ease: "power2.out",
            },
            "-=0.8",
        );
    }

    // ─── Eventos ─────────────────────────
    initBtn.addEventListener("click", () => {
        clearTimeout(autoTimer);
        triggerExplosion();
    });

    // Auto-detonación tras 4 segundos
    let autoTimer = setTimeout(triggerExplosion, 4000);

    window.addEventListener("resize", resizeCanvas);

    // ─── Arranque ────────────────────────
    resizeCanvas();
    createParticles();
    animationLoop();
</script>
